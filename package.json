{
  "name": "turborepo-template",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "clean": "turbo clean",
    "dev": "turbo dev",
    "doc": "tsx scripts/doc.ts && typedoc && cp _config.yml docs && tsx scripts/add-frontmatter.ts",
    "format": "biome check . --write",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "prepare": "husky",
    "rebrand": "tsx scripts/rebrand.ts",
    "release": "tsx ./scripts/publish.ts",
    "sync": "turborepo-template-upgrade",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "upgrade": "tsx ./scripts/upgrade.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@changesets/cli": "^2.31.0",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.9.5",
    "enquirer": "^2.4.1",
    "husky": "^9.1.7",
    "plop": "^4.0.5",
    "tsx": "^4.23.1",
    "turbo": "^2.10.5",
    "turborepo-template-upgrade": "^0.8.0",
    "typedoc": "^0.28.20",
    "typedoc-plugin-markdown": "^4.12.0",
    "typedoc-plugin-mdn-links": "^5.1.1",
    "typedoc-plugin-missing-exports": "^4.1.4",
    "typedoc-plugin-rename-defaults": "^0.7.3"
  },
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=20"
  }
}
